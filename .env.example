NODE_ENV=production
HOST=0.0.0.0
PORT=4173
MAX_BODY_BYTES=64000

# Qwen Cloud / Alibaba Cloud Model Studio
QWEN_API_KEY=
DASHSCOPE_API_KEY=
QWEN_API_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL_DEFAULT=qwen-plus
QWEN_AGENT_TIMEOUT_MS=30000
QWEN_AGENT_RETRY_COUNT=1
QWEN_LIVE_CALLS=false

# Alibaba Cloud deployment proof and managed data targets
ALIBABA_CLOUD_REGION=us-west-1
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
ALIBABA_COMPUTE_TARGET=ECS
ALIBABA_DATABASE_TARGET=RDS for PostgreSQL
ALIBABA_RDS_POSTGRES_URL=

# CrisisOps safety controls
AUTO_EXECUTE_CONFIDENCE_THRESHOLD=0.90
RUNBOOK_ALLOWLIST=RB-101,RB-204,RB-330,RB-401,RB-510,RB-777
SLACK_APPROVER_IDS=U-HACK-JUDGE,U-ONCALL-PRIMARY
DEDUPE_WINDOW_MS=180000
VERIFICATION_TIMEOUT_MS=30000
REMEDIATION_EXECUTION_MODE=dry-run

# MCP live toggles
MCP_ALERTS_LIVE=false
MCP_LOGS_LIVE=false
MCP_METRICS_LIVE=false
MCP_TRACES_LIVE=false
MCP_MEMORY_LIVE=false
MCP_GITHUB_LIVE=false
MCP_CHAT_LIVE=false
MCP_TICKETS_LIVE=false
MCP_DEPLOY_LIVE=false
MCP_DOCS_LIVE=false
MCP_PAGER_LIVE=false

# MCP provider credentials
ALERTMANAGER_BASE_URL=
DATADOG_API_KEY=
DATADOG_APP_KEY=
PROMETHEUS_BASE_URL=
PROMETHEUS_USER=
PROMETHEUS_PASSWORD=
OTEL_COLLECTOR_URL=
GITHUB_TOKEN=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
CONFLUENCE_BASE_URL=
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=
PAGERDUTY_API_TOKEN=
KUBECONFIG_PATH=

# Demo/test toggles
FORCE_QWEN_FAILURE_ROLE=
FORCE_VERIFICATION_FAIL=
