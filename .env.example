NODE_ENV=production
HOST=0.0.0.0
PORT=4173
MAX_BODY_BYTES=64000

# Qwen Cloud / Alibaba Cloud Model Studio
QWEN_API_KEY=
DASHSCOPE_API_KEY=
QWEN_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_AGENT_TIMEOUT_MS=8000
QWEN_AGENT_RETRY_COUNT=1

# Alibaba Cloud deployment proof and managed data targets
ALIBABA_CLOUD_REGION=us-west-1
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
ALIBABA_COMPUTE_TARGET=ECS
ALIBABA_DATABASE_TARGET=RDS for PostgreSQL
ALIBABA_RDS_POSTGRES_URL=

# CrisisOps safety controls
AUTO_EXECUTE_CONFIDENCE_THRESHOLD=0.90
RUNBOOK_ALLOWLIST=RB-101,RB-204,RB-330,RB-401,RB-510
SLACK_APPROVER_IDS=U-HACK-JUDGE,U-ONCALL-PRIMARY
DEDUPE_WINDOW_MS=180000
VERIFICATION_TIMEOUT_MS=30000

# Demo/test toggles
FORCE_QWEN_FAILURE_ROLE=
FORCE_VERIFICATION_FAIL=
